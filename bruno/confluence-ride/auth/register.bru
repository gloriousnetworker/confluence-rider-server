meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "name": "Test User",
    "phone": "+2349099999999",
    "password": "TestPass123"
  }
}

assert {
  res.status: eq 201
  res.body.success: eq true
  res.body.data.userId: isDefined
}

script:post-response {
  if (res.body.data && res.body.data.otp) {
    bru.setVar("otp", res.body.data.otp);
    bru.setVar("registeredPhone", "+2349099999999");
  }
}

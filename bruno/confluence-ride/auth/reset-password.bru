meta {
  name: Reset Password
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/auth/reset-password
  body: json
  auth: none
}

body:json {
  {
    "phone": "+2348012345678",
    "code": "{{resetOtp}}",
    "newPassword": "NewPass456"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

meta {
  name: Login
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "phone": "+2348012345678",
    "password": "Password123"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

script:post-response {
  if (res.body.data && res.body.data.accessToken) {
    bru.setVar("accessToken", res.body.data.accessToken);
    bru.setVar("refreshToken", res.body.data.refreshToken);
  }
}

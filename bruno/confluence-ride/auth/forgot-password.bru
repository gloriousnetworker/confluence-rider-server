meta {
  name: Forgot Password
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/auth/forgot-password
  body: json
  auth: none
}

body:json {
  {
    "phone": "+2348012345678"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

script:post-response {
  if (res.body.data && res.body.data.otp) {
    bru.setVar("resetOtp", res.body.data.otp);
  }
}
